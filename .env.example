# Provider: anthropic or gemini
PROVIDER=anthropic

# ── Anthropic ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx
MODEL_ID=claude-sonnet-4-6
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# DeepSeek (Anthropic-compatible)
# ANTHROPIC_API_KEY=your-deepseek-key
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# MODEL_ID=deepseek-chat

# ── Gemini ─────────────────────────────────────
# GEMINI_API_KEY=key1,key2,key3   # comma-separated, auto-rotate on 429
# GEMINI_MODEL=gemini-2.5-flash

# ── Web Search (Google Custom Search) ─────────
# SEARCH_API_KEY=your-google-api-key
# SEARCH_CX=your-search-engine-id
# Get these at: https://programmablesearchengine.google.com/

# ── Web Fetch Summary Model ──────────────────
# SUMMARY_PROVIDER=deepseek       # deepseek, gemini, or anthropic
# SUMMARY_MODEL=deepseek-chat     # model for preprocessing web content
